# ============================================================
# crosscheck-agent — API keys for multi-LLM conferral
# Copy this file to .env and fill in the providers you want to use.
# Any provider left blank is simply skipped at runtime.
# ============================================================

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (GPT) — https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# xAI (Grok) — OpenAI-compatible endpoint, https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-4-latest

# Google (Gemini) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Mistral — https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
